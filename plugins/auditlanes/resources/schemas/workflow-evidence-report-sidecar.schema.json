{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auditlanes.local/schemas/workflow-evidence-report-sidecar.schema.json",
  "title": "AuditLanes workflow evidence report sidecar",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sidecar_id",
    "generated_at",
    "run_id",
    "batch_id",
    "family",
    "mode",
    "profile",
    "strategy",
    "overlays",
    "baseline_commit",
    "reviewed_artifacts",
    "reviewed_files_routes_helpers",
    "coverage_units_touched",
    "confirmed_findings",
    "candidate_findings",
    "rejected_claims",
    "clone_maps",
    "runtime_updates",
    "chain_candidates",
    "coverage_gaps",
    "profile_feedback",
    "incidental_leads",
    "risk_signals",
    "proof_updates",
    "regression_recommendations",
    "workflow_entity_updates",
    "workflow_edge_updates",
    "workflow_evidence_updates",
    "scenario_observation_updates",
    "workflow_score_updates",
    "workflow_card_updates",
    "segment_card_updates",
    "fixture_card_updates",
    "workflow_unknown_updates",
    "next_batch_recommendations"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "sidecar_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1, "format": "date-time" },
    "run_id": { "type": "string", "minLength": 1 },
    "batch_id": { "type": "string", "pattern": "^batch-[0-9][0-9]$" },
    "family": { "$ref": "#/$defs/id" },
    "mode": {
      "enum": [
        "static-scout",
        "static-classify",
        "fixture-gap-scout",
        "tenant-segment-sweep",
        "business-aggregate-sweep",
        "runtime-log-sweep",
        "task-side-effect-sweep",
        "fixture-audit",
        "evidence-gap-fill",
        "backlog-synthesis",
        "release-selection",
        "atlas-synthesis",
        "parked"
      ]
    },
    "profile": { "const": "workflow-evidence" },
    "strategy": { "$ref": "#/$defs/id" },
    "overlays": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" }
    },
    "profile_version": { "type": ["string", "null"] },
    "baseline_commit": { "type": ["string", "null"] },
    "reviewed_artifacts": { "$ref": "#/$defs/stringList" },
    "reviewed_files_routes_helpers": { "$ref": "#/$defs/stringList" },
    "shared_context_inputs": { "$ref": "#/$defs/stringList" },
    "coverage_units_touched": { "$ref": "#/$defs/stringList" },
    "coverage_units_not_touched": { "$ref": "#/$defs/stringList" },
    "patterns_searched": { "$ref": "#/$defs/stringList" },
    "intentionally_excluded": { "$ref": "#/$defs/objectList" },
    "confirmed_findings": { "$ref": "#/$defs/objectList" },
    "candidate_findings": { "$ref": "#/$defs/objectList" },
    "rejected_claims": { "$ref": "#/$defs/objectList" },
    "clone_maps": { "$ref": "#/$defs/objectList" },
    "runtime_updates": { "$ref": "#/$defs/objectList" },
    "chain_candidates": { "$ref": "#/$defs/objectList" },
    "coverage_gaps": { "$ref": "#/$defs/objectList" },
    "profile_feedback": { "$ref": "#/$defs/objectList" },
    "incidental_leads": { "$ref": "#/$defs/objectList" },
    "security_smells": { "$ref": "#/$defs/objectList" },
    "risk_signals": { "$ref": "#/$defs/objectList" },
    "proof_updates": { "$ref": "#/$defs/objectList" },
    "regression_recommendations": { "$ref": "#/$defs/objectList" },
    "run_local_checks": { "$ref": "#/$defs/objectList" },
    "workflow_entity_updates": { "$ref": "#/$defs/objectList" },
    "workflow_edge_updates": { "$ref": "#/$defs/objectList" },
    "workflow_evidence_updates": { "$ref": "#/$defs/objectList" },
    "scenario_observation_updates": { "$ref": "#/$defs/objectList" },
    "workflow_score_updates": { "$ref": "#/$defs/objectList" },
    "workflow_card_updates": { "$ref": "#/$defs/objectList" },
    "segment_card_updates": { "$ref": "#/$defs/objectList" },
    "fixture_card_updates": { "$ref": "#/$defs/objectList" },
    "workflow_unknown_updates": { "$ref": "#/$defs/objectList" },
    "next_batch_recommendations": { "$ref": "#/$defs/stringList" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "objectList": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
