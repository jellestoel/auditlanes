{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auditlanes.local/schemas/unowned-surface.schema.json",
  "title": "AuditLanes unowned surface JSONL row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "surface_id",
    "reason",
    "paths",
    "risk_hint",
    "status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "surface_id": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "paths": { "type": "array", "items": { "type": "string" } },
    "risk_hint": { "type": "string", "minLength": 1 },
    "status": { "enum": ["requires-triage", "assigned", "accepted-risk"] }
  }
}
