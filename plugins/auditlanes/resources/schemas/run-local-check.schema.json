{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auditlanes.local/schemas/run-local-check.schema.json",
  "title": "AuditLanes run-local check JSONL row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "check_id",
    "source_family",
    "source_reports",
    "first_seen_batch",
    "last_touched_batch",
    "reason",
    "trigger_evidence_refs",
    "scope_impact",
    "status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "check_id": { "type": "string", "pattern": "^local\\.[a-z0-9][a-z0-9.-]*$" },
    "source_family": { "type": "string", "minLength": 1 },
    "recommended_owner_family": { "type": ["string", "null"] },
    "source_reports": {
      "type": "array",
      "items": { "type": "object" }
    },
    "first_seen_batch": { "type": "string", "pattern": "^batch-[0-9][0-9]$" },
    "last_touched_batch": { "type": "string", "pattern": "^batch-[0-9][0-9]$" },
    "reason": { "type": "string", "minLength": 1 },
    "trigger_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "extends_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scope_impact": { "type": "string", "minLength": 1 },
    "regression_impact": { "type": ["string", "null"] },
    "status": { "enum": ["active", "promoted", "retired"] }
  }
}
