{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auditlanes.local/schemas/security-invariant.schema.json",
  "title": "AuditLanes security invariant JSONL row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "invariant_id",
    "summary",
    "asset_types",
    "principal_types",
    "actions",
    "expected_controls",
    "owner_family",
    "secondary_families",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "invariant_id": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "asset_types": { "type": "array", "items": { "type": "string" } },
    "principal_types": { "type": "array", "items": { "type": "string" } },
    "actions": { "type": "array", "items": { "type": "string" } },
    "expected_controls": { "type": "array", "items": { "type": "string" } },
    "owner_family": { "type": "string", "minLength": 1 },
    "secondary_families": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "object" } }
  }
}
