{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auditlanes.local/schemas/risk-signal.schema.json",
  "title": "AuditLanes risk signal JSONL row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "signal_id",
    "category",
    "source_family",
    "source_reports",
    "first_seen_batch",
    "last_touched_batch",
    "path",
    "description",
    "recommended_owner",
    "status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "signal_id": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "source_family": { "type": "string", "minLength": 1 },
    "source_reports": { "type": "array", "items": { "type": "object" } },
    "first_seen_batch": { "type": "string", "pattern": "^batch-[0-9][0-9]$" },
    "last_touched_batch": { "type": "string", "pattern": "^batch-[0-9][0-9]$" },
    "path": { "type": "string", "minLength": 1 },
    "line_start": { "type": ["integer", "null"], "minimum": 1 },
    "description": { "type": "string", "minLength": 1 },
    "recommended_owner": { "type": "string", "minLength": 1 },
    "status": { "enum": ["needs-triage", "promoted", "rejected"] }
  }
}
